# ================================
# LifemarkAI Environment Variables
# ================================
# Copy this file to .env.local and fill in your values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Providers ---
# OpenRouter — single key for Claude, GPT, Gemini, Llama, DeepSeek, and 200+ models.
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Route ALL AI tools through OpenRouter (default: true when OPENROUTER_API_KEY is set)
AI_VIA_OPENROUTER=true

# Direct provider keys (optional when AI_VIA_OPENROUTER=true)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=sk-groq-...
GROQ_API_BASE_URL=https://api.groq.com/openai/v1

# Google Gemini — powers the Gemini 3 Flash chat tier AND Nano Banana 2
# (gemini-3.1-flash-image) native image generation. Recommended.
# Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...
# Native slugs (claude-opus-4-8) auto-map to OpenRouter (anthropic/claude-opus-4-8) when AI_VIA_OPENROUTER=true

# --- SEO Integrations (optional) ---
# Enables live Semrush research in the SEO panel
SEMRUSH_API_KEY=

# --- GitHub OAuth App ---
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...
NEXT_PUBLIC_GITHUB_CLIENT_ID=...
GITHUB_APP_PRIVATE_KEY=...

# --- GitLab OAuth App (https://gitlab.com/-/profile/applications) ---
# Scopes: api, read_user  |  Redirect URI: <APP_URL>/api/gitlab/connect
GITLAB_CLIENT_ID=...
GITLAB_CLIENT_SECRET=...
NEXT_PUBLIC_GITLAB_CLIENT_ID=...

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe recurring Price IDs — must match the names read in lib/stripe/plans.ts.
# Create a Product per plan in Stripe, each with a monthly + yearly recurring price.
# (Enterprise is custom-quoted — no price ID. Credit packs are created dynamically.)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...    # Pro  — $20/mo
STRIPE_PRO_YEARLY_PRICE_ID=price_...     # Pro  — $16/mo billed yearly
STRIPE_TEAM_MONTHLY_PRICE_ID=price_...   # Team — $60/mo
STRIPE_TEAM_YEARLY_PRICE_ID=price_...    # Team — $48/mo billed yearly

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@lifemarkai.app

# --- Deployment ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=lifemarkai.app

# --- Vercel (for deploying user projects) ---
VERCEL_TOKEN=...
VERCEL_TEAM_ID=...

# --- Netlify (real deployment of user projects) ---
# Create a personal access token at https://app.netlify.com/user/applications
NETLIFY_AUTH_TOKEN=...

# --- Figma (import designs) ---
# Users provide their own Figma tokens in the UI — no server-side token needed

# --- Image Generation ---
# Primary: Nano Banana 2 (needs GOOGLE_GENERATIVE_AI_API_KEY above).
# Fallback: DALL-E 3 (uses OPENAI_API_KEY) when Google isn't configured.

# --- App Settings ---
# Per-task model tiers live in lib/ai/editor-intelligence.ts (MODEL_TIERS):
#   coding=claude-opus-4-8, planning=gpt-5.2, chat=gemini-3-flash-preview.
# These two only override the non-routed default/fast picks.
DEFAULT_AI_MODEL=claude-opus-4-8
FAST_AI_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS_PER_REQUEST=8000
# Build mode output cap per model call (default 32000 — fewer continuation rounds on large apps)
BUILD_MAX_TOKENS=32000
FREE_DAILY_CREDITS=5
PRO_MONTHLY_CREDITS=100
BUSINESS_MONTHLY_CREDITS=300

# --- Self-verification (Lovable-style "agent verifies its own output") ---
# When true (and the `playwright` package is installed), builds are rendered in
# headless Chromium and runtime errors are auto-fixed. Falls back to static
# checks when unset. See lib/ai/self-verify.ts.
# Set true + `npm install playwright` for full headless-browser self-verify (lib/ai/self-verify.ts)
PLAYWRIGHT_ENABLED=true

# --- Scheduled tasks (cron auth) ---
# Required in production. Shared secret for /api/cloud/daily-backups and
# /api/cloud/bill-usage (sent as x-cron-secret header). Vercel crons in vercel.json.
CRON_SECRET=your-cron-shared-secret

# --- Lifemark Cloud — managed backend provisioning (optional) ---
# Set BOTH to provision a real dedicated Supabase project per app (auth/db/
# storage/edge functions, auto-wired into generated apps). Without them, Cloud
# runs in "local mode". Token: https://supabase.com/dashboard/account/tokens
SUPABASE_MANAGEMENT_TOKEN=sbp_...
SUPABASE_ORG_ID=your-org-id

# --- Sentry (error tracking) ---
# Create a project at https://sentry.io and grab the DSN
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=lifemarkai
SENTRY_AUTH_TOKEN=sntrys_...

# --- Redis (job queue — optional, enables Bull/BullMQ) ---
# Set to a Redis URL to enable async deploy queue + notification queue
# Redis Cloud free tier: https://redis.com/try-free/
# Upstash (serverless): https://upstash.com/
REDIS_URL=redis://localhost:6379

# --- Logging ---
# Minimum log level: debug | info | warn | error (default: info in production)
LOG_LEVEL=info


# --- AI Gateway (Cloudflare Worker) ---
# Leave unset to use direct provider keys (local dev / self-hosted).
# Set both to route all AI calls through ai.gateway.lifemarkai.app.
LIFEMARK_GATEWAY_URL=https://ai.gateway.lifemarkai.app
LIFEMARK_GATEWAY_SECRET=your-gateway-shared-secret

# --- Feature flags (new capabilities — all OFF by default, opt in gradually) ---
# Switch heavy AI tiers to Claude Opus 4.8 + fast/chat to Haiku 4.5.
# Leave unset to keep the prior models (Sonnet heavy, gpt-4o-mini fast).
# Slugs use OpenRouter DOT notation (anthropic/claude-opus-4.8,
# anthropic/claude-sonnet-4.6, anthropic/claude-haiku-4.5) — verified on
# openrouter.ai (2026). NOT the hyphen native-API ids.
LIFEMARK_CLAUDE_DEFAULTS=false
# Max build output tokens. Default 32000 (prior behavior). Set 64000 for
# complete-app single-pass builds on Claude/Gemini (auto-clamped per model).
BUILD_MAX_TOKENS=32000
# Real sandbox preview (E2B). Requires E2B_API_KEY + `npm i @e2b/code-interpreter`.
# When "1", the editor preview runs the app in a cloud sandbox and shows a live URL.
NEXT_PUBLIC_ENABLE_SANDBOX_PREVIEW=0
# E2B_API_KEY=your-e2b-key
# E2B_TEMPLATE=your-e2b-template-id

# --- Domain purchase (optional — in-product domain registration) ---
# DOMAIN_REGISTRAR=cloudflare
# CLOUDFLARE_API_TOKEN=your-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# IONOS_API_KEY=your-ionos-key
