{
  "name": "lifemarkai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "verify:parity": "npx tsx scripts/verify-lovable-gaps.ts && npx tsx scripts/verify-tier2-gaps.ts && npx tsx scripts/verify-tier3-gaps.ts && npx tsx scripts/verify-tier5-gaps.ts",
    "verify:production": "npx tsx scripts/verify-production-ready.ts",
    "verify:smoke": "node scripts/verify-production-smoke.mjs",
    "electron:dev": "NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron electron/main.js\"",
    "electron:build": "npm run build && electron-builder --config electron/electron-builder.yml",
    "electron:build:mac": "npm run build && electron-builder --mac --config electron/electron-builder.yml",
    "electron:build:win": "npm run build && electron-builder --win --config electron/electron-builder.yml",
    "electron:build:linux": "npm run build && electron-builder --linux --config electron/electron-builder.yml",
    "cap:sync": "cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "cap run ios",
    "cap:run:android": "cap run android"
  },
